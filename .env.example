# Required only for direct `boundaryci scan --fireworks`; managed Cloud review uses no customer provider key.
FIREWORKS_API_KEY=fw_your_key_here

# Required only for `boundaryci scan --upload`.
# Use the deployed ingest-scan Edge Function URL.
BOUNDARYCI_CLOUD_URL=https://your-project.supabase.co/functions/v1/ingest-scan
BOUNDARYCI_CLOUD_TOKEN=bci_your_repository_token_here
